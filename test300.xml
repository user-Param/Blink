<file path="executor/include/adapter/oadapter.h">
#ifndef OADAPTER_H
#define OADAPTER_H

#include <memory>
#include <string>
#include <atomic>

class Executor {
    public:
        bool connected_;
};

struct OrderRequest {
    std::string order_id;
    std::string symbol;
    double price;
    int quantity;
    std::string side;  // "BUY" or "SELL"
    std::string type;  // "LIMIT", "MARKET"
    uint64_t timestamp;
};

class OAdapter {
public:
    OAdapter();
    ~OAdapter();

    // Receive order from RiskManager - DIRECT SEND (no queue)
    void onOrderSignal(const OrderRequest& order);

    void setCallback(const std::string& order_id, const std::string& status, const std::string& message);
    
    // Start the adapter
    void run();
    void stop();
    
    // Set exchange to send orders to
    void setExchange(const std::string& exchange_id);
    
private:
    // Send order to exchange immediately
    void sendOrder(const OrderRequest& order);
    
    std::unique_ptr<Executor> exchange_;
    std::string exchange_id_;
    std::atomic<bool> running_{false};
};

#endif
</file>

